# Required
SECRET_KEY=change_this_to_a_long_random_secret_at_least_32_chars

# Admin bootstrap
ADMIN_EMAIL=admin@sentinel.ai
ADMIN_PASSWORD=Admin@Sentinel2024

# CORS — add your Next.js dev URL
ALLOWED_ORIGINS=http://localhost:8000,http://localhost:3000,http://127.0.0.1:3000,http://localhost:5500,http://127.0.0.1:5500

# Optional: Anthropic API key for AI Copilot LLM responses
# Without this, the copilot uses keyword-based fallback responses
ANTHROPIC_API_KEY=sk-ant-...

# Incident API (internal)
INCIDENT_API=http://localhost:8000/incidents/
